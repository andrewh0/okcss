{
  "name": "okcss",
  "version": "1.2.2",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "./scripts/build.sh",
    "deploy": "yarn build && mkdir -p _site && cp src/ok.css dist/ok.min.css index.html demo.html _site/",
    "start": "yarn run serve .",
    "version": "yarn build && git add src/ok.css dist/ok.min.css",
    "release:dry": "yarn auto shipit --dry-run",
    "release": "yarn auto shipit"
  },
  "dependencies": {
    "lightningcss-cli": "^1.31.1",
    "serve": "^11.3.2"
  },
  "devDependencies": {
    "@auto-it/pr-body-labels": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@auto-it/upload-assets": "^11.3.6",
    "auto": "^11.3.6"
  }
}
